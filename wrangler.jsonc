{
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "kosatka",
  "compatibility_date": "2025-09-02",
  // Static-assets-only deployment: no Worker script, no server runtime.
  // The app is fully client-side (see vite.config.ts header). SPA fallback
  // serves the prerendered shell for deep links like /mix/<uuid> and
  // /rpf/<id> so the client router can take over.
  "assets": {
    "directory": "dist/client",
    "not_found_handling": "single-page-application",
  },
}
